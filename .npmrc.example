# ============================================================
# CONSUMER SETUP — copy this file to .npmrc in the consuming
# project to install @tomscaria/scaria-design-system from
# GitHub Packages (private registry).
# ============================================================
#
# 1. Generate a GitHub Personal Access Token (classic) at
#    https://github.com/settings/tokens with `read:packages` scope.
#    OR use a fine-grained token with "Packages: Read" permission
#    on the scaria-design-system repo.
#
# 2. Export it as an env var (do NOT commit the actual token):
#      export NPM_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxx
#
# 3. Copy this file to .npmrc in the consuming project root.
#
# 4. npm install @tomscaria/scaria-design-system
#
# ============================================================

@tomscaria:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NPM_GITHUB_TOKEN}
always-auth=true
