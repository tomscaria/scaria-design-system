{
  "$schema": "https://scaria-design-system.tomscaria.com/schemas/theme-tokens.json",
  "name": "earth-light",
  "description": "Default Lore brand on parchment surface. Graphite ink, lime accent.",
  "mode": "light",
  "expressions": ["product", "marketing"],
  "color": {
    "background": "hsl(40 30% 92%)",
    "foreground": "hsl(0 0% 8%)",
    "brand": "hsl(0 0% 8%)",
    "accent": "hsl(82 100% 55%)",
    "accent_hover": "hsl(82 100% 48%)",
    "accent_deep": "hsl(82 100% 35%)",
    "success": "hsl(102 28% 28%)",
    "danger": "hsl(8 65% 44%)"
  },
  "type": {
    "families": {
      "sans": "Aeonik",
      "display": "Lock Serif",
      "mono": "Aeonik Mono"
    },
    "scale_product": {
      "display_xl": { "size_px": 96, "line_height": 0.95 },
      "display_lg": { "size_px": 72, "line_height": 1.0 },
      "display_md": { "size_px": 56, "line_height": 1.05 },
      "header_lg":  { "size_px": 24, "line_height": 1.2 },
      "body_md":    { "size_px": 16, "line_height": 1.55 }
    },
    "scale_marketing_deltas": {
      "display_xl": { "size_px": 120 },
      "display_lg": { "size_px": 96 },
      "display_md": { "size_px": 72 }
    }
  },
  "motion": {
    "duration_entry_ms_product": 200,
    "duration_entry_ms_marketing": 600,
    "ease_reveal": "cubic-bezier(0.25, 0.46, 0.45, 0.94)"
  },
  "spacing": {
    "section_y_product_px": 48,
    "section_y_marketing_px": 160
  },
  "radii_px": { "xs": 4, "sm": 8, "md": 12, "lg": 16, "xl": 24 }
}
