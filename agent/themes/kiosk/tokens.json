{
  "$schema": "https://lore-design-system.tomscaria.com/schemas/theme-tokens.json",
  "name": "kiosk",
  "description": "Brutalist newsstand. Sharp corners, electric yellow accent, hard-edge shadows, Syne display.",
  "mode": "light",
  "expressions": ["marketing", "product"],
  "color": {
    "background": "hsl(0 0% 100%)",
    "foreground": "hsl(0 0% 0%)",
    "brand": "hsl(0 0% 0%)",
    "accent": "hsl(63 100% 58%)",
    "accent_soft": "hsl(63 100% 92%)",
    "danger": "hsl(0 100% 41%)"
  },
  "type": {
    "families": { "sans": "Syne", "display": "Syne", "mono": "IBM Plex Mono" },
    "scale_product": {
      "display_xl": { "size_px": 128, "line_height": 0.9 },
      "display_lg": { "size_px": 96, "line_height": 0.92 },
      "header_lg":  { "size_px": 28, "line_height": 1.1 },
      "body_md":    { "size_px": 16, "line_height": 1.5 }
    },
    "scale_marketing_deltas": {
      "display_xl": { "size_px": 180 },
      "display_lg": { "size_px": 128 }
    },
    "weight_default": 500,
    "weight_emphasis": 800
  },
  "motion": { "duration_entry_ms": 200, "ease_ambient": "linear", "note": "No spring easing in kiosk." },
  "spacing": { "section_y_product_px": 64, "section_y_marketing_px": 200 },
  "radii_px": { "xs": 0, "sm": 0, "md": 0, "lg": 0, "xl": 0 },
  "shadow_style": "hard offset, no blur",
  "use_for": ["pricing pages", "one-pagers", "statements of intent"],
  "avoid_for": ["dashboards", "data-dense product UI"]
}
