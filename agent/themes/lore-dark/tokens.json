{
  "$schema": "https://scaria-design-system.tomscaria.com/schemas/theme-tokens.json",
  "name": "lore-dark",
  "description": "Inversion of lore-light. Graphite surface, parchment ink, lime accent (hero).",
  "mode": "dark",
  "expressions": ["product", "marketing"],
  "color": {
    "background": "hsl(80 5% 8%)",
    "foreground": "hsl(40 30% 92%)",
    "brand": "hsl(82 100% 55%)",
    "accent": "hsl(82 100% 55%)",
    "accent_hover": "hsl(82 100% 48%)",
    "accent_deep": "hsl(82 100% 35%)",
    "danger": "hsl(8 80% 73%)"
  },
  "type": {
    "families": { "sans": "Aeonik", "display": "Lock Serif", "mono": "Aeonik Mono" },
    "scale_product": {
      "display_xl": { "size_px": 96, "line_height": 0.95 },
      "display_lg": { "size_px": 72, "line_height": 1.0 },
      "header_lg":  { "size_px": 24, "line_height": 1.2 },
      "body_md":    { "size_px": 16, "line_height": 1.55 }
    }
  },
  "motion": { "duration_entry_ms_product": 200, "duration_entry_ms_marketing": 600 },
  "spacing": { "section_y_product_px": 48, "section_y_marketing_px": 160 },
  "radii_px": { "xs": 4, "sm": 8, "md": 12, "lg": 16, "xl": 24 },
  "pairs_with": "lore-light"
}
