{
  "$schema": "https://scaria-design-system.tomscaria.com/schemas/theme-tokens.json",
  "name": "primitive",
  "alias": "primitive-light",
  "description": "THE STUDIO — Scaria flagship marketing theme. Lore parchment + chartreuse material, Revenant one-accent discipline, terminal amber garnish. Default public identity (tomscaria.com).",
  "mode": "light",
  "expressions": ["product", "marketing"],
  "color": {
    "background": "#F0ECE1",
    "foreground": "#1A1B18",
    "brand": "#1A1B18",
    "accent": "#D4F24B",
    "accent_deep": "#56730D",
    "accent_soft": "#DCEAC5",
    "term_amber": "#E8A33D",
    "glow": "#A9BD85",
    "danger": "#B85C3A"
  },
  "type": {
    "families": { "sans": "Aeonik", "display": "Lock Serif", "mono": "Aeonik Mono" },
    "scale_product": {
      "display_xl": { "size_px": 96, "line_height": 0.98 },
      "display_lg": { "size_px": 64, "line_height": 1.02 },
      "header_lg":  { "size_px": 22, "line_height": 1.18 },
      "body_md":    { "size_px": 15, "line_height": 1.55 }
    },
    "scale_marketing_deltas": {
      "display_xl": { "size_px": 132, "line_height": 0.94 },
      "display_lg": { "size_px": 88 }
    }
  },
  "motion": { "duration_entry_ms_product": 220, "duration_entry_ms_marketing": 600, "ease_interaction": "cubic-bezier(0.2, 0.8, 0.2, 1)" },
  "spacing": { "section_y_product_px": 56, "section_y_marketing_px": 120 },
  "radii_px": { "xs": 2, "sm": 4, "md": 6, "lg": 8, "xl": 12 },
  "brand_layer": {
    "hero_plate": "the painted trading studio (public/brand/primitive/hero-studio-*.webp in consumers)",
    "constants": ["crosshair cursor + chartreuse click tick", "paper grain overlay", "section dial n/N", "letterspaced kicker with moss dot", "amber ticker tape"],
    "css": "agent/visual/patterns/brand-layer.css"
  },
  "pairs_with": "primitive-dark"
}
