{
  "$schema": "https://scaria-design-system.tomscaria.com/schemas/theme-tokens.json",
  "name": "primitive",
  "alias": "primitive-light",
  "description": "Brand-neutral Inter-based theme. Documentation, agent baselines, brand-free demos.",
  "mode": "light",
  "expressions": ["product"],
  "color": {
    "background": "hsl(0 0% 100%)",
    "foreground": "hsl(0 0% 4%)",
    "brand": "hsl(0 0% 4%)",
    "accent": "hsl(0 0% 4%)",
    "danger": "hsl(0 70% 50%)"
  },
  "type": {
    "families": { "sans": "Inter", "display": "Inter", "mono": "ui-monospace" },
    "scale_product": {
      "display_xl": { "size_px": 80, "line_height": 0.96 },
      "display_lg": { "size_px": 60, "line_height": 1.0 },
      "header_lg":  { "size_px": 22, "line_height": 1.2 },
      "body_md":    { "size_px": 15, "line_height": 1.55 }
    }
  },
  "motion": { "duration_entry_ms_product": 300, "ease_interaction": "cubic-bezier(0.4, 0, 0.2, 1)" },
  "spacing": { "section_y_product_px": 72 },
  "radii_px": { "xs": 4, "sm": 6, "md": 8, "lg": 10, "xl": 14 },
  "pairs_with": "primitive-dark"
}
