{
  "$schema": "https://lore-design-system.tomscaria.com/schemas/theme-tokens.json",
  "name": "revenant-dark",
  "description": "Revenant brand on deep charcoal surface. Concrete-gray off-white ink, brick-orange signal accent. Trading-floor-at-midnight mode.",
  "mode": "dark",
  "expressions": ["product", "marketing"],
  "color": {
    "background": "hsl(15 5% 9%)",
    "foreground": "hsl(32 12% 88%)",
    "brand": "hsl(20 80% 56%)",
    "accent": "hsl(20 80% 56%)",
    "accent_hover": "hsl(20 80% 62%)",
    "accent_deep": "hsl(20 78% 38%)",
    "accent_soft": "hsl(20 35% 18%)",
    "success": "hsl(140 28% 52%)",
    "danger": "hsl(6 65% 58%)"
  },
  "type": {
    "families": {
      "sans": "Aeonik",
      "display": "Aeonik",
      "mono": "Aeonik Mono"
    },
    "scale_product": {
      "display_xl": { "size_px": 96, "line_height": 0.92 },
      "display_lg": { "size_px": 72, "line_height": 0.97 },
      "display_md": { "size_px": 56, "line_height": 1.02 },
      "header_lg":  { "size_px": 24, "line_height": 1.18 },
      "body_md":    { "size_px": 15, "line_height": 1.42 }
    },
    "scale_marketing_deltas": {
      "display_xl": { "size_px": 112 },
      "display_lg": { "size_px": 88 },
      "display_md": { "size_px": 68 }
    }
  },
  "motion": {
    "duration_entry_ms_product": 160,
    "duration_entry_ms_marketing": 380,
    "ease_reveal": "cubic-bezier(0.4, 0, 0.15, 1)"
  },
  "spacing": {
    "section_y_product_px": 32,
    "section_y_marketing_px": 144
  },
  "radii_px": { "xs": 2, "sm": 3, "md": 4, "lg": 6, "xl": 8 }
}
