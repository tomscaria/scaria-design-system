{
  "$schema": "https://lore-design-system.tomscaria.com/schemas/theme-tokens.json",
  "name": "revenant-light",
  "description": "Revenant brand on concrete-gray surface. Warm near-black ink, brick-orange signal accent. No Lock Serif.",
  "mode": "light",
  "expressions": ["product", "marketing"],
  "color": {
    "background": "hsl(32 12% 93%)",
    "foreground": "hsl(14 8% 10%)",
    "brand": "hsl(14 8% 10%)",
    "accent": "hsl(20 82% 50%)",
    "accent_hover": "hsl(20 82% 43%)",
    "accent_deep": "hsl(20 80% 30%)",
    "accent_soft": "hsl(20 60% 92%)",
    "success": "hsl(140 22% 28%)",
    "danger": "hsl(6 60% 42%)"
  },
  "type": {
    "families": {
      "sans": "Aeonik",
      "display": "Aeonik",
      "mono": "Aeonik Mono"
    },
    "notes": "No Lock Serif — that typeface belongs to Lore. Aeonik carries all display weight for Revenant. Aeonik Mono is used heavily for calibration values, lifecycle badges, system labels, metadata.",
    "scale_product": {
      "display_xl": { "size_px": 96, "line_height": 0.92 },
      "display_lg": { "size_px": 72, "line_height": 0.97 },
      "display_md": { "size_px": 56, "line_height": 1.02 },
      "header_lg":  { "size_px": 24, "line_height": 1.18 },
      "body_md":    { "size_px": 15, "line_height": 1.42 }
    },
    "scale_marketing_deltas": {
      "display_xl": { "size_px": 112 },
      "display_lg": { "size_px": 88 },
      "display_md": { "size_px": 68 }
    }
  },
  "motion": {
    "duration_entry_ms_product": 160,
    "duration_entry_ms_marketing": 380,
    "ease_reveal": "cubic-bezier(0.4, 0, 0.15, 1)"
  },
  "spacing": {
    "section_y_product_px": 32,
    "section_y_marketing_px": 144
  },
  "radii_px": { "xs": 2, "sm": 3, "md": 4, "lg": 6, "xl": 8 }
}
