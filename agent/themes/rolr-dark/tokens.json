{
  "$schema": "https://lore-design-system.tomscaria.com/schemas/theme-tokens.json",
  "name": "rolr-dark",
  "description": "ROLR prediction-market book. Near-black warm olive surface, ember primary, lime hero accent, live-presence pink. The Pro / desktop surface.",
  "mode": "dark",
  "expressions": ["product", "marketing"],
  "color": {
    "background": "hsl(75 24% 8%)",
    "background_2": "hsl(90 11% 10%)",
    "foreground": "hsl(43 38% 91%)",
    "line": "hsl(94 9% 17%)",
    "brand": "hsl(19 64% 58%)",
    "brand_hover": "hsl(18 56% 51%)",
    "accent": "hsl(72 85% 62%)",
    "accent_hover": "hsl(72 73% 55%)",
    "accent_deep": "hsl(76 74% 43%)",
    "accent_soft": "hsl(72 85% 62% / 0.14)",
    "up": "hsl(132 31% 63%)",
    "down": "hsl(18 71% 60%)",
    "live": "hsl(335 100% 65%)",
    "win": "hsl(72 85% 62%)",
    "success": "hsl(132 31% 63%)",
    "danger": "hsl(18 71% 60%)"
  },
  "type": {
    "families": { "sans": "Aeonik", "display": "Lock Serif", "mono": "Aeonik Mono" },
    "notes": "Lock Serif carries hero numbers (balances, pots) and section openers. Aeonik Mono carries every live readout: prices, cents, latency, player counts, volume, countdowns — anything that updates. Tabular slashed-zero is mandatory on numerics.",
    "scale_product": {
      "display_md": { "size_px": 52, "line_height": 1.02 },
      "header_lg":  { "size_px": 23, "line_height": 1.05 },
      "body_md":    { "size_px": 14, "line_height": 1.5 },
      "caps":       { "size_px": 10, "tracking_em": 0.13 }
    }
  },
  "motion": {
    "duration_entry_ms_product": 200,
    "duration_live_ms": 1300,
    "duration_pop_ms": 350,
    "ease_ambient": "ease-in-out",
    "ease_pop": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "signature": "liveness-forward, organic pulse"
  },
  "spacing": { "section_y_product_px": 40, "section_y_marketing_px": 128 },
  "radii_px": { "xs": 6, "sm": 8, "md": 11, "lg": 14, "xl": 18 }
}
