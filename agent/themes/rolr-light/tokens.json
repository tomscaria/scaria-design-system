{
  "$schema": "https://scaria-design-system.tomscaria.com/schemas/theme-tokens.json",
  "name": "rolr-light",
  "description": "ROLR casual (iOS) surface. Warm white, graphite primary, deep-lime accent, ember for the no/down side. The phone-first, games-first surface.",
  "mode": "light",
  "expressions": ["product", "marketing"],
  "color": {
    "background": "hsl(46 100% 97%)",
    "background_2": "hsl(0 0% 100%)",
    "foreground": "hsl(80 5% 8%)",
    "line": "hsl(42 38% 87%)",
    "brand": "hsl(80 5% 8%)",
    "brand_hover": "hsl(80 5% 14%)",
    "accent": "hsl(74 56% 54%)",
    "accent_hover": "hsl(76 64% 45%)",
    "accent_deep": "hsl(99 33% 27%)",
    "accent_soft": "hsl(70 55% 84%)",
    "up": "hsl(99 33% 27%)",
    "down": "hsl(18 53% 47%)",
    "live": "hsl(335 100% 65%)",
    "win": "hsl(74 73% 62%)",
    "success": "hsl(99 33% 27%)",
    "danger": "hsl(18 53% 47%)"
  },
  "type": {
    "families": { "sans": "Aeonik", "display": "Lock Serif", "mono": "Aeonik Mono" },
    "notes": "Same type identity as rolr-dark. Lock Serif for greetings + hero pot values, Aeonik Mono for all live readouts. Casual surface keeps numbers large and readable.",
    "scale_product": {
      "display_lg": { "size_px": 58, "line_height": 1.02 },
      "header_lg":  { "size_px": 20, "line_height": 1.05 },
      "body_md":    { "size_px": 14, "line_height": 1.5 },
      "caps":       { "size_px": 10, "tracking_em": 0.13 }
    }
  },
  "motion": {
    "duration_entry_ms_product": 200,
    "duration_live_ms": 1300,
    "duration_pop_ms": 350,
    "ease_ambient": "ease-in-out",
    "ease_pop": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "signature": "liveness-forward, organic pulse"
  },
  "spacing": { "section_y_product_px": 40, "section_y_marketing_px": 128 },
  "radii_px": { "xs": 6, "sm": 8, "md": 13, "lg": 17, "xl": 22 }
}
