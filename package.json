{
  "name": "@tomscaria/scaria-design-system",
  "version": "1.3.1",
  "description": "Lore design system — tokens (colors, type, spacing), themes (lore-light/dark, revenant-light/dark, kiosk, primitive), kit CSS primitives, Tailwind preset, and thin React component wrappers. Consumed by swarm-fund-mvp, Thomas OS, lore-teaser-prea.",
  "license": "UNLICENSED",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./derived/npm/index.js",
  "module": "./derived/npm/index.mjs",
  "types": "./derived/npm/index.d.ts",
  "files": [
    "agent/",
    "derived/npm/",
    "tokens/",
    "fonts/",
    "preview/_primitives.css",
    "preview/_revenant-kit.css",
    "preview/_dataviz-kit.css",
    "preset.cjs",
    "styles.css",
    "magic_trick.md",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./derived/npm/index.d.ts",
      "import": "./derived/npm/index.mjs",
      "require": "./derived/npm/index.js"
    },
    "./css": "./tokens/colors_and_type.css",
    "./css/primitives": "./tokens/primitives.css",
    "./css/kit": "./preview/_revenant-kit.css",
    "./css/dataviz": "./preview/_dataviz-kit.css",
    "./css/layouts": "./preview/_primitives.css",
    "./tokens.json": "./tokens/tokens.json",
    "./fonts/*": "./fonts/*",
    "./package.json": "./package.json",
    "./preset": {
      "default": "./preset.cjs"
    },
    "./tailwind": {
      "default": "./preset.cjs"
    },
    "./styles": {
      "default": "./styles.css"
    },
    "./themes/lore-light": "./agent/themes/lore-light/colors_and_type.css",
    "./themes/lore-dark": "./agent/themes/lore-dark/colors_and_type.css",
    "./themes/primitive": "./agent/themes/primitive/colors_and_type.css",
    "./themes/primitive-dark": "./agent/themes/primitive-dark/colors_and_type.css",
    "./themes/revenant-light": "./agent/themes/revenant-light/colors_and_type.css",
    "./themes/revenant-dark": "./agent/themes/revenant-dark/colors_and_type.css",
    "./themes/kiosk": "./agent/themes/kiosk/colors_and_type.css",
    "./themes/rolr-light": "./agent/themes/rolr-light/colors_and_type.css",
    "./themes/rolr-dark": "./agent/themes/rolr-dark/colors_and_type.css",
    "./dataviz": "./agent/visual/dataviz/dataviz.css",
    "./patterns": "./agent/visual/patterns/patterns.css",
    "./orbfield": "./agent/visual/patterns/orbfield.css",
    "./orbfield.js": "./agent/visual/patterns/orbfield.js",
    "./leadrow": "./agent/visual/patterns/leadrow.css",
    "./brand-layer": "./agent/visual/patterns/brand-layer.css",
    "./botw": "./agent/visual/botw/botw-flair.css",
    "./glyphs/ledger": "./agent/visual/glyphs/ledger-glyphs.svg",
    "./motion": "./agent/visual/motion/motion.css",
    "./motion.json": "./agent/visual/motion/motion.json",
    "./agent/*": "./agent/*",
    "./magic_trick": "./magic_trick.md",
    "./brands/lore/magic_trick": "./agent/brands/lore/magic_trick.md",
    "./brands/revenant/magic_trick": "./agent/brands/revenant/magic_trick.md"
  },
  "scripts": {
    "build": "node scripts/build-derived.mjs",
    "build:tsc": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "lint": "echo 'no lint configured yet'",
    "test": "echo 'no tests configured yet'",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=3.4.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "tailwindcss": {
      "optional": false
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "design-system",
    "atomic-kit",
    "tailwind-preset",
    "lore",
    "revenant",
    "scaria",
    "tokens",
    "themes"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tomscaria/scaria-design-system.git"
  },
  "author": "Thomas Scaria <tomscaria@gmail.com>",
  "homepage": "https://github.com/tomscaria/scaria-design-system#readme"
}
